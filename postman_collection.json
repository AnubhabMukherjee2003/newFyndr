    {
      "name": "Admin Roles",
      "item": [
        {
          "name": "Create Role Schema",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"student-role-id\",\n  \"roleName\": \"Student\",\n  \"assignedRoles\": [\"teacher-role-id\"],\n  \"profileTemplate\": {\n    \"college\": \"string\"\n  },\n  \"requireModules\": [\n    {\n      \"module_id\": \"learning-module-id\",\n      \"weight\": 0.6,\n      \"target_role\": \"teacher-role-id\",\n      \"question\": \"Choose what you want to learn\",\n      \"input_type\": \"MULTI_CHOICE\",\n      \"data_type\": \"VECTOR\",\n      \"match_type\": \"OVERLAP_MATCH\",\n      \"options\": [\"Math\", \"Physics\", \"CS\"]\n    }\n  ],\n  \"provideModules\": [\n    {\n      \"module_id\": \"year-module-id\",\n      \"weight\": 0.4,\n      \"target_role\": null,\n      \"question\": \"Which year are you in?\",\n      \"input_type\": \"SINGLE_CHOICE\",\n      \"data_type\": \"VECTOR\",\n      \"match_type\": \"OVERLAP_MATCH\",\n      \"options\": [\"1st\", \"2nd\", \"3rd\"]\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/admin/roles",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "roles"]
            }
          }
        },
